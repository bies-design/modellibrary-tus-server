model Account {
  id String @id @default(uuid())

  // 對應 userId: { type: Schema.Types.ObjectId, ref: "User", required: true }
  userId String
  // 定義外鍵關聯：當 User 被刪除時，Account 也一併刪除 (Cascade) 一個account 只能有一個user
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 對應 password: { type: String }
  password String?

  // 對應 provider: { type: String, required: true }
  provider String

  // 對應 providerAccountId: { type: String, required: true }
  providerAccountId String

  // 對應 timestamps: true
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 建立複合索引 (可選，但推薦)：避免同一個 provider 重複綁定同一個 ID
  @@unique([provider, providerAccountId])
}

model Comment {
  id      String @id @default(cuid())
  content String // 留言內容

  // 1. 關聯到貼文 (Post 被刪除時，留言一併刪除)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 2. 關聯到留言作者 (User 被刪除時，留言一併刪除)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 3. 自我關聯：「回覆留言」功能
  // parentId 為 null 代表是「主留言」；有值代表是「回覆別人的留言」
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// prisma/schema/main.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 共用的 Enum 建議放在這裡，或者跟隨主要使用的 Model
enum ProcessStatus {
  uploading
  processing
  completed
  error
}

// prisma/schema/model.prisma

model Model {
  id      String @id @default(uuid())
  shortId String @unique // 用於分享的短 ID
  name    String // 原始檔名
  fileId  String @unique // MinIO / Tus ID (關鍵關聯)

  // 建立與 User 的關聯
  uploaderId String // 外鍵欄位
  uploader   User   @relation(fields: [uploaderId], references: [id])
  size       String @default("") // 檔案大小 (bytes)

  status       ProcessStatus @default(uploading)
  errorMessage String?

  // 關聯：Prisma 會自動跨檔案識別 Post 模型
  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// prisma/schema/pdfs.prisma

model Pdf {
  id     String @id @default(uuid())
  name   String // 原始檔名
  fileId String @unique // MinIO / Tus ID (關鍵關聯)

  // 建立與 User 的關聯
  uploaderId String // 外鍵欄位
  uploader   User   @relation(fields: [uploaderId], references: [id])

  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// prisma/schema/post.prisma

model Post {
  id          String  @id @default(uuid())
  shortId     String  @unique
  title       String
  category    String
  description String?
  type        String

  // PostgreSQL 的原生陣列功能
  keywords   String[]
  coverImage String
  images     String[]

  // 關聯到 Model (3D 檔案)
  models Model[]

  pdfIds     Pdf[]
  // pdf Pdf @relation(fields: [pdfId], references: [id])
  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  // 相關文章 ID (簡易關聯)
  relatedPosts String[]

  permission String

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull) //當團隊解散所有的TeamMember會自動清空

  // 貼文可以同時被掛載到無數個不同的ProjectNode上 可以複用
  nodes ProjectNode[]

  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // 權限與擁有者 (可根據你現有系統調整)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // 👥 關聯到 Team (專案所屬團隊，如果是個人專案則為 null)
  teamId String?
  team   Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  // 一個專案包含多個節點
  nodes  ProjectNode[]
}

model ProjectNode {
  id   String @id @default(uuid())
  name String // 例如："A棟", "2F機房", "冰水主機"

  // 綁定所屬的 Project (當專案刪除時，底下節點一併刪除)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 樹狀結構自我關聯
  parentId String? // 如果是 null，代表是該專案的最頂層節點
  parent   ProjectNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children ProjectNode[] @relation("NodeHierarchy")

  // 🔗 關聯到你現有的 Post (模型 / PDF)
  // 一個節點可以掛載多個 Post，例如一個「2F機房」節點可以掛一個 3D 模型 Post 和三個 PDF 圖紙 Post
  posts Post[]
}

model Team {
  id          String       @id @default(cuid())
  name        String // 團隊名稱
  description String? // 團隊介紹
  avatar      String? // 團隊 Logo (存 MinIO 的檔名或路徑)
  color       String? // 團隊顏色 (標住在postcard上面)
  // 關聯
  members     TeamMember[] // 團隊成員與他們的權限
  posts       Post[] // 該團隊擁有的所有模型貼文
  projects    Project[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum TeamRole {
  OWNER // 建立者 (擁有最高權限，可刪除團隊)
  ADMIN // 管理員 (可邀請/踢除成員、編輯團隊資訊)
  EDITOR // 編輯者 (可上傳、編輯、刪除團隊內的模型)
  VIEWER // 瀏覽者 (僅能觀看，無法修改)
}

// 團隊與使用者的中介表 (用來記錄「誰」在「哪個團隊」是什麼「角色」)
model TeamMember {
  id   String   @id @default(cuid())
  role TeamRole @default(VIEWER)

  // 關聯到 Team
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade) //若Team不在 則刪除整筆資料

  // 關聯到 User
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade) //若User不在 則刪除整筆資料

  joinedAt DateTime @default(now())

  // 確保同一個使用者不會在同一個團隊被重複加入兩次
  @@unique([teamId, userId])
}

enum Role {
  Free
  Pro
}

model User {
  // 使用 String 型別以兼容舊的 MongoDB ObjectId，新資料預設使用 cuid
  id String @id @default(uuid())

  // 對應 userName: { type: String, required: true, unique: true }
  userName String @unique

  // 對應 email: { type: String, required: true, unique: true }
  email String @unique

  // 對應 role: { type: String, enum: ["Free", "Pro"], required: true }
  role Role @default(Free)

  // 對應 image: { type: String }
  image String?

  teamMembers TeamMember[]

  // 對應 userCollection: { type: [Schema.Types.ObjectId] }
  userCollection String[]

  // 建立與 Account 的關聯 (User 能有多個 Account) provider不同會有不同account
  accounts Account[]

  // 一個使用者可以擁有多個模型
  models Model[]

  pdfs Pdf[]

  posts    Post[]
  comments Comment[]

  projects  Project[]
  // 對應 timestamps: true
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
