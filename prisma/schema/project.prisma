enum ProjectStatus {
  ACTIVE      // 進行中
  ON_HOLD     // 暫停中
  COMPLETED   // 已完工
  ARCHIVED    // 封存備查
}
// 專案與階段架構
model Project {
    id          String   @id @default(uuid())
    name        String
    description String?
    client      String?  // 業主
    location    String?  // 地點
    coverImage  String?
    status      ProjectStatus   @default(ACTIVE)

    teamId      String
    team        Team    @relation(fields: [teamId], references: [id], onDelete: Restrict)//防止手殘
    // 專案的實際管理權限由 TeamMember 的 Role 決定，這個欄位只用來紀錄「最初是誰建的」
    creatorId   String
    creator     User          @relation(fields: [creatorId], references: [id])
    
    phases      Phase[]
    assets      ProjectAsset[] // 掛載的 Post

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}