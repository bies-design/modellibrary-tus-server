model Account {
  id String @id @default(uuid())

  // 對應 userId: { type: Schema.Types.ObjectId, ref: "User", required: true }
  userId String
  // 定義外鍵關聯：當 User 被刪除時，Account 也一併刪除 (Cascade) 一個account 只能有一個user
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 對應 password: { type: String }
  password String?

  // 對應 provider: { type: String, required: true }
  provider String

  // 對應 providerAccountId: { type: String, required: true }
  providerAccountId String

  // 對應 timestamps: true
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 建立複合索引 (可選，但推薦)：避免同一個 provider 重複綁定同一個 ID
  @@unique([provider, providerAccountId])
}

model Comment {
  id      String @id @default(cuid())
  content String // 留言內容

  // 1. 關聯到貼文 (Post 被刪除時，留言一併刪除)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 2. 關聯到留言作者 (User 被刪除時，留言一併刪除)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 3. 自我關聯：「回覆留言」功能
  // parentId 為 null 代表是「主留言」；有值代表是「回覆別人的留言」
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1. 統整所有檔案類型的 Enum
enum FileCategory {
  MODEL_3D // .ifc, .3dm, .obj, .gltf
  DRAWING // .dwg, .pdf, .png
  DOCUMENT // .pdf, .docx, .xlsx
  IMAGE // .jpg, .png, .webp
  OTHER // 其他未知格式
}

// 2. 將原本的 Model 和 Pdf 合併成這一張表 
model FileRecord {
  id           String       @id @default(uuid())
  shortId      String?      @unique // 如果有單檔分享需求可留
  name         String // 原始檔名 (e.g., "A棟結構.ifc", "報價單.pdf")
  fileId       String       @unique // MinIO / Tus ID (關鍵關聯)
  viewerFileId String?
  category     FileCategory @default(OTHER) // 大分類
  extension    String? // 副檔名紀錄 (e.g., ".3dm", ".pdf")
  size         String       @default("") // 檔案大小 (bytes)

  status       ProcessStatus @default(completed)
  errorMessage String?

  // 新增這兩行：讓檔案一上傳就能指定歸屬團隊 (可以為 null 代表純私人)
  teamId     String?
  team       Team?   @relation(fields: [teamId], references: [id], onDelete: Restrict)
  // 關聯到上傳者
  uploaderId String
  uploader   User    @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  // 關聯到 Post：一個檔案屬於一篇 Post
  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// prisma/schema/main.prisma

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
}

// 共用的 Enum 建議放在這裡，或者跟隨主要使用的 Model
enum ProcessStatus {
  uploading
  processing
  completed
  error
}

model Phase {
  id        String @id @default(uuid())
  name      String // "概念設計", "細部設計" 等
  sortOrder Int    @default(0)

  projectId  String
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // 該階段下的「頂層」資源節點
  rootAssets ProjectAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// prisma/schema/post.prisma

model Post {
  id          String  @id @default(uuid())
  shortId     String  @unique
  title       String
  category    String
  description String?
  type        String

  // PostgreSQL 的原生陣列功能
  keywords   String[]
  coverImage String?
  images     String[]

  // 任何檔案類型都可以兼容
  files      FileRecord[]
  // pdf Pdf @relation(fields: [pdfId], references: [id])
  uploaderId String
  uploader   User         @relation(fields: [uploaderId], references: [id])

  // 相關文章 ID (簡易關聯)
  relatedPosts String[]

  permission String

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull) //當團隊解散所有的TeamMember會自動清空

  comments Comment[]

  projectAssets ProjectAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectStatus {
  ACTIVE // 進行中
  ON_HOLD // 暫停中
  COMPLETED // 已完工
  ARCHIVED // 封存備查
}

// 專案與階段架構
model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  client      String? // 業主
  location    String? // 地點
  coverImage  String?
  status      ProjectStatus @default(ACTIVE)

  teamId    String
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Restrict) //防止手殘
  // 專案的實際管理權限由 TeamMember 的 Role 決定，這個欄位只用來紀錄「最初是誰建的」
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  phases Phase[]
  assets ProjectAsset[] // 掛載的 Post

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1. 定義節點類型
enum AssetType {
  FOLDER // 代表這是一個資料夾
  POST // 代表這是一個內部的 Post 資源
  LINK // 代表這是一個外部 URL 連結
}

// 專案中介表 (橋接 Project, Phase 與 Post)
model ProjectAsset {
  id          String    @id @default(uuid())
  name        String? // 如果是資料夾或連結，手動命名；如果是 Post，可以選填（預設抓 Post Title）
  description String?
  type        AssetType @default(POST)
  sortOrder   Int       @default(0)

  // --- 樹狀結構核心 ---
  parentId String?
  parent   ProjectAsset?  @relation("AssetToAsset", fields: [parentId], references: [id], onDelete: Cascade)
  children ProjectAsset[] @relation("AssetToAsset")

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 如果這是一個頂層節點，它會屬於一個 Phase；
  // 如果它是子節點，則透過 parentId 溯源（或者為了查詢方便，也可以保留這個欄位）
  phaseId String? //null表示未分類
  phase   Phase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  // --- 內容關聯 (三選一邏輯) ---
  // A. 關聯到內部的 Post
  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // B. 存儲外部 URL
  url String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 建立索引加速樹狀查詢
  @@index([parentId])
  @@index([projectId])
}

model Team {
  id          String       @id @default(cuid())
  name        String // 團隊名稱
  description String? // 團隊介紹
  avatar      String? // 團隊 Logo (存 MinIO 的檔名或路徑)
  color       String? // 團隊顏色 (標住在postcard上面)
  // 關聯
  members     TeamMember[] // 團隊成員與他們的權限
  posts       Post[] // 該團隊擁有的所有模型貼文
  files       FileRecord[] // 該團隊擁有的所有fileRecord
  projects    Project[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum TeamRole {
  OWNER // 建立者 (擁有最高權限，可刪除團隊)
  ADMIN // 管理員 (可邀請/踢除成員、編輯團隊資訊)
  EDITOR // 編輯者 (可上傳、編輯、刪除團隊內的模型)
  VIEWER // 瀏覽者 (僅能觀看，無法修改)
}

// 團隊與使用者的中介表 (用來記錄「誰」在「哪個團隊」是什麼「角色」)
model TeamMember {
  id   String   @id @default(cuid())
  role TeamRole @default(VIEWER)

  // 關聯到 Team
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade) //若Team不在 則刪除整筆資料

  // 關聯到 User
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade) //若User不在 則刪除整筆資料

  joinedAt DateTime @default(now())

  // 確保同一個使用者不會在同一個團隊被重複加入兩次
  @@unique([teamId, userId])
}

enum Role {
  Free
  Pro
}

model User {
  // 使用 String 型別以兼容舊的 MongoDB ObjectId，新資料預設使用 cuid
  id String @id @default(uuid())

  // 對應 userName: { type: String, required: true, unique: true }
  userName String @unique

  // 對應 email: { type: String, required: true, unique: true }
  email String @unique

  // 對應 role: { type: String, enum: ["Free", "Pro"], required: true }
  role Role @default(Free)

  // 對應 image: { type: String }
  image String?

  teamMembers TeamMember[]

  // 對應 userCollection: { type: [Schema.Types.ObjectId] }
  userCollection String[]

  // 建立與 Account 的關聯 (User 能有多個 Account) provider不同會有不同account
  accounts Account[]

  fileRecords FileRecord[]

  posts    Post[]
  comments Comment[]

  projects  Project[]
  // 對應 timestamps: true
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
