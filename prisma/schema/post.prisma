// prisma/schema/post.prisma

model Post {
  id       String @id @default(uuid())
  shortId  String @unique
  title    String
  category String
  description String?
  type     String

  // PostgreSQL 的原生陣列功能
  keywords   String[]
  coverImage String
  images     String[]

  // 任何檔案類型都可以兼容
  files     FileRecord[]
  // pdf Pdf @relation(fields: [pdfId], references: [id])
  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  // 相關文章 ID (簡易關聯)
  relatedPosts String[]

  permission String

  teamId     String?
  team  Team? @relation(fields: [teamId], references: [id], onDelete: SetNull) //當團隊解散所有的TeamMember會自動清空

  comments Comment[]
  
  projectAssets ProjectAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
