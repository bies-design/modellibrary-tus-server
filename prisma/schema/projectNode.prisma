model ProjectNode {
    id          String        @id @default(uuid())
    name        String        // 例如："A棟", "2F機房", "冰水主機"
    
    // 綁定所屬的 Project (當專案刪除時，底下節點一併刪除)
    projectId   String
    project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

    // 樹狀結構自我關聯
    parentId    String?       // 如果是 null，代表是該專案的最頂層節點
    parent      ProjectNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
    children    ProjectNode[] @relation("NodeHierarchy")

    // 🔗 關聯到你現有的 Post (模型 / PDF)
    // 一個節點可以掛載多個 Post，例如一個「2F機房」節點可以掛一個 3D 模型 Post 和三個 PDF 圖紙 Post
    posts       Post[]
}