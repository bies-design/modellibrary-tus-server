// 1. 統整所有檔案類型的 Enum
enum FileCategory {
    MODEL_3D  // .ifc, .3dm, .obj, .gltf
    DRAWING   // .dwg, CAD 圖紙
    DOCUMENT  // .pdf, .docx, .xlsx
    IMAGE     // .jpg, .png
    OTHER     // 其他未知格式
}

// 2. 將原本的 Model 和 Pdf 合併成這一張表 
model FileRecord {
    id           String        @id @default(uuid())
    shortId      String?       @unique // 如果有單檔分享需求可留
    name         String        // 原始檔名 (e.g., "A棟結構.ifc", "報價單.pdf")
    fileId       String        @unique // MinIO / Tus ID (關鍵關聯)
    
    category     FileCategory  @default(OTHER) // 大分類
    extension    String?       // 副檔名紀錄 (e.g., ".3dm", ".pdf")
    size         String        @default("") // 檔案大小 (bytes)
    
    status       ProcessStatus @default(completed)
    errorMessage String?

    // 關聯到上傳者
    uploaderId   String
    uploader     User          @relation(fields: [uploaderId], references: [id])

    // 關聯到 Post：一個檔案屬於一篇 Post
    postId       String?       
    post         Post?         @relation(fields: [postId], references: [id], onDelete: Cascade)

    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
}